NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3001

# SSO_API_URL:
#   Local:      http://localhost:8000/api/v1
#   Production: https://sso-self.vercel.app/api/v1
SSO_API_URL=https://sso-self.vercel.app/api/v1

